# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False

# Data Paths
DATA_DIR=./data
LEXICON_DIR=./data/lexicons
EMBEDDING_DIR=./data/embeddings
DATASET_DIR=./data/datasets

# Language Configuration
DEFAULT_LANGUAGE=english
SUPPORTED_LANGUAGES=english,hindi,marathi,bhojpuri,marwari

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
